API_PORT=3000
PASSWORD=""

# --- Sonarr (required) ------------------------------------------------------
# NOTE: include the API version in the URL (/api/v3).
SONARR_API_BASE_URL="http://sonarr.local:8989/api/v3"
SONARR_API_KEY=""
SONARR_QUALITY_PROFILE_ID=3
SONARR_BASE_PATH="/anime/"

# --- TheTVDB (optional fallback) --------------------------------------------
# Matching now uses free AniList + Fribb/ARM ID mapping first; a TVDB v4 key is
# only an extra fallback for shows those miss. Commented = not required by
# dotenv-safe. Uncomment in your real .env to enable the TVDB fallback.
# TVDB_API_KEY=""

# --- Radarr (optional: enables anime movies) --------------------------------
# RADARR_API_BASE_URL="https://radarr.local/api/v3"
# RADARR_API_KEY=""
# RADARR_QUALITY_PROFILE_ID=1
# RADARR_BASE_PATH="/movies/anime/"
# RADARR_MINIMUM_AVAILABILITY="released"
