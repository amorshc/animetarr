API_PORT=3000
TVDB_API_KEY=""
PASSWORD=""
SONARR_API_BASE_URL="https://sonarr.local/api/v3"
SONARR_API_KEY=""
SONARR_QUALITY_PROFILE_ID=3
SONARR_BASE_PATH="/downloads/anime/"

# --- Radarr (optional: enables anime movies) --------------------------------
# Commented on purpose: dotenv-safe treats keys in this file as REQUIRED, so
# leaving these commented keeps Sonarr-only setups working. Uncomment in your
# real .env to enable movies.
# Select http or https based on your requirement below
# RADARR_API_BASE_URL="https://radarr.local/api/v3"
# RADARR_API_KEY=""
# RADARR_QUALITY_PROFILE_ID=1
# RADARR_BASE_PATH="/movies/anime/"
# RADARR_MINIMUM_AVAILABILITY="released"
